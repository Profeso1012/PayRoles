VITE_API_URL=/api
VITE_APP_NAME=PayRole
VITE_APP_ENV=development

# API Integration Mode
# Set to 'true' to use real backend, 'false' to use MSW mocks
VITE_USE_REAL_API=false

# Backend URL (when using real API)
# For local development with real backend running on port 3000:
# VITE_API_URL=http://localhost:3000/api

