# Environment Configuration Example
# Copy this file to .env.local and update with your settings

# Application
VITE_APP_NAME=PayRole
VITE_APP_ENV=development

# API Integration Mode
# Set to 'false' to use Mock Service Worker (MSW) for local development
# Set to 'true' to connect to real backend
VITE_USE_REAL_API=false

# API Base URL
# When VITE_USE_REAL_API=false (using MSW): Use /api
# When VITE_USE_REAL_API=true (using real backend): Use full backend URL
VITE_API_URL=/api

# Real Backend Configuration (when VITE_USE_REAL_API=true)
# Uncomment and update these when connecting to real backend:
# VITE_API_URL=http://localhost:3000/api
# VITE_USE_REAL_API=true

# For production backend:
# VITE_API_URL=https://api.payrole.com/api
# VITE_USE_REAL_API=true
